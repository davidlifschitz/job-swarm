# ml-job-swarm — Railway + Supabase hosted deployment
#
# Copy to Railway service variables (web + worker). Do not commit real secrets.
# See docs/tier2-hosted-web.md and scripts/railway-preflight.sh.
#
# Phase A: SQLite on a Railway volume at /data (volume required).
# Phase B: Supabase Postgres + Storage (recommended for production).
#
# Verify after deploy:
#   curl -sS https://your-app.up.railway.app/healthz
#   ./scripts/smoke-hosted.sh https://your-app.up.railway.app
#   ./scripts/railway-preflight.sh
#   PREFLIGHT_POSTGRES=1 ./scripts/railway-preflight.sh

# -----------------------------------------------------------------------------
# Core (required — web and worker)
# -----------------------------------------------------------------------------

# Public URL of the Railway web service (no trailing slash).
ML_JOB_SWARM_PUBLIC_URL=https://your-app.up.railway.app

# Supabase project URL (Project Settings → API).
SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable anon key (sb_publishable_...). Safe for browser; required for auth.
SUPABASE_ANON_KEY=sb_publishable_your_anon_key_here

# -----------------------------------------------------------------------------
# Phase A — SQLite on Railway volume
# -----------------------------------------------------------------------------
# Mount a Railway volume at /data. Omit DATABASE_URL and Phase B Storage vars.
# /healthz reports database_backend: sqlite, resume_storage_backend: local.

ML_JOB_SWARM_DATA_DIR=/data

# -----------------------------------------------------------------------------
# Phase B — Supabase Postgres + Storage (production cutover)
# -----------------------------------------------------------------------------
# Set on web + worker. Volume optional after migration.
# /healthz reports database_backend: postgresql when DATABASE_URL is set.
# resume_storage_backend: supabase when SUPABASE_SERVICE_ROLE_KEY + SUPABASE_URL are set.

# Session pooler URI (Supabase → Database → connection string).
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Server-only secret (sb_secret_...). Required for resume uploads to Storage.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key_here

# Private Storage bucket name (create in Supabase; default resume-assets).
ML_JOB_SWARM_RESUME_STORAGE_BUCKET=resume-assets

# Legacy HS256 projects only — omit when using JWKS (new Supabase projects).
# SUPABASE_JWT_SECRET=your-legacy-jwt-secret

# -----------------------------------------------------------------------------
# Cloud worker (second Railway service, same image)
# -----------------------------------------------------------------------------
# Set ML_JOB_SWARM_PROCESS=worker on the worker service only (not the web service).
# Phase A: mount the same volume at /data. Phase B: same DATABASE_URL + SUPABASE_* as web.

# ML_JOB_SWARM_PROCESS=worker

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# LLM fit review (OpenRouter). Leave unset to disable.
# OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
