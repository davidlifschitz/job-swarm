# ml-job-swarm — Maintainer production ops environment template
#
# Copy to a local, gitignored file (e.g. .env.ops.local) and fill with real values.
# Do not commit secrets. Used by OPS-1–3 runbooks in docs/tier2-hosted-web.md and
# scripts/run-production-ops.sh (when present).
#
# Recommended execution order: OPS-2 → OPS-1 → OPS-3
#   OPS-2  Supabase link, migrations, Storage bucket, secret rotation
#   OPS-1  Railway Phase B cutover (SQLite → Postgres, worker deploy)
#   OPS-3  Apple notarization / Tier 3 macOS release
#
# Verify locally without production secrets:
#   ./scripts/verify-ops-readiness.sh
#
# Check which vars are set before live ops:
#   ./scripts/run-production-ops.sh --check-env   # when orchestrator is available
#   ./scripts/railway-cutover.sh --check-env
#   ./scripts/sync-supabase-secrets.sh --check-env
#   ./scripts/notarize-macos-app.sh --require

# =============================================================================
# OPS-2 — Supabase hygiene (link, db push, bucket, secret rotation)
# =============================================================================
# Scripts: bootstrap-supabase.sh, sync-supabase-secrets.sh [--railway]
# Supabase CLI: supabase login --token "$SUPABASE_ACCESS_TOKEN"

# Supabase project ref (Dashboard → Project Settings → General).
# OPS-2: supabase link, projects api-keys, db push
SUPABASE_PROJECT_REF=your-project-ref

# Personal access token for non-interactive CLI login.
# Create at https://supabase.com/dashboard/account/tokens
# OPS-2: supabase login --token
SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token_here

# Session pooler URI (Supabase → Database → Connection string).
# OPS-2: supabase db push, local migration validation
# OPS-1: live SQLite → Postgres cutover (railway-cutover.sh)
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Server-only secret (sb_secret_...). Dashboard → Project Settings → API.
# OPS-2: rotate and push to Railway for resume Storage uploads
# OPS-1: required on Railway web + worker (Phase B)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key_here

# =============================================================================
# OPS-1 — Railway Phase B cutover
# =============================================================================
# Scripts: railway-cutover.sh, migrate-sqlite-to-postgres.sh
# After cutover: redeploy Railway web + worker with Phase B env vars.

# Path to exported hosted SQLite database (jobs.db from Railway volume).
# OPS-1: railway-cutover.sh (required for live migration)
ML_JOB_SWARM_SOURCE_DB=/path/to/exported/jobs.db

# Directory containing resume asset files from the hosted volume export.
# OPS-1: railway-cutover.sh (optional if no resume files to migrate)
ML_JOB_SWARM_RESUME_ASSET_DIR=/path/to/exported/resume-assets

# Public URL of the Railway web service (no trailing slash).
# OPS-1: post-cutover smoke (--smoke-only), health checks
ML_JOB_SWARM_PUBLIC_URL=https://your-app.up.railway.app

# Bearer token for authenticated smoke endpoints (if app enforces access control).
# OPS-1: railway-cutover.sh --smoke-only [ACCESS_TOKEN]
ML_JOB_SWARM_ACCESS_TOKEN=your_optional_bearer_token_here

# --- Railway Phase B service variables (from .env.hosted.example) ---
# Set on both web and worker services after OPS-2 completes.
# See .env.hosted.example and docs/tier2-hosted-web.md for full hosted catalog.

# Supabase project URL (Project Settings → API).
# OPS-1: Railway web + worker (Phase B); synced via sync-supabase-secrets.sh --railway
SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable anon key (sb_publishable_...). Safe for browser; required for auth.
# OPS-1: Railway web + worker (Phase B); synced via sync-supabase-secrets.sh --railway
SUPABASE_ANON_KEY=sb_publishable_your_anon_key_here

# Private Storage bucket name (create in Supabase; default resume-assets).
# OPS-1: Railway web + worker (Phase B resume uploads)
ML_JOB_SWARM_RESUME_STORAGE_BUCKET=resume-assets

# Worker service only — omit on web service.
# OPS-1: deploy cloud worker as second Railway service
# ML_JOB_SWARM_PROCESS=worker

# =============================================================================
# OPS-3 — Apple notarization / Tier 3 macOS release
# =============================================================================
# Script: notarize-macos-app.sh [--require]
# Requires macOS with Xcode command line tools.

# Keychain profile name (preferred). Create with:
#   xcrun notarytool store-credentials "YOUR_PROFILE"
# OPS-3: notarize-macos-app.sh (alternative to APPLE_ID trio below)
NOTARYTOOL_PROFILE=your-notarytool-keychain-profile

# --- Alternative to NOTARYTOOL_PROFILE (use one auth method, not both) ---

# Apple ID email for the Developer account.
# OPS-3: notarize-macos-app.sh
APPLE_ID=you@example.com

# App-specific password (appleid.apple.com → Sign-In and Security).
# OPS-3: notarize-macos-app.sh
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# 10-character Team ID (Developer account membership).
# OPS-3: notarize-macos-app.sh
APPLE_TEAM_ID=XXXXXXXXXX

# Code signing identity. Use "-" for ad-hoc local builds; set to your
# "Developer ID Application: …" certificate for release notarization.
# OPS-3: notarize-macos-app.sh → sign-macos-app.sh
CODESIGN_IDENTITY=Developer ID Application: Your Name (TEAMID)
